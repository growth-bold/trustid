# ============================================================
# TrustID — Mẫu biến môi trường
# Sao chép file này thành `.env` (hoặc `.env.local`) rồi điền giá trị.
#   cp .env.example .env
# File `.env.example` được commit làm tài liệu; `.env` thì KHÔNG.
# ============================================================

# URL công khai của site — dùng cho canonical, OpenGraph, ảnh OG (/og-image).
# Bắt buộc có https, không dấu "/" ở cuối. Là biến NEXT_PUBLIC_* nên
# được nhúng lúc `next build` → đặt đúng giá trị trước khi build production.
NEXT_PUBLIC_SITE_URL=https://trust.growthbold.co

# --- Tùy chọn ---
# NEXT_TELEMETRY_DISABLED=1
# PORT=3000
